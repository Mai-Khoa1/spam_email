{
  "manifest_version": 3,
  "name": "Gmail Spam Detector AI",
  "version": "1.0",
  "description": "Tự động chèn nút kiểm tra Spam và kết nối API Flask để nhận diện thư rác trên Gmail.",
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "http://localhost:5000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://mail.google.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "content.css"
      ]
    }
  ]
}
